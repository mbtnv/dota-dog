# Example environment file for docker-compose.prod.yml on the production server.
# Copy this file to /opt/dota-dog/stack.env and replace placeholder secrets.

BOT_TOKEN=replace-me
POSTGRES_DB=dota_dog
POSTGRES_USER=dota_dog
POSTGRES_PASSWORD=replace-me
OPENDOTA_BASE_URL=https://api.opendota.com/api
OPENDOTA_API_KEY=
POLL_INTERVAL_MINUTES=15
DEFAULT_TIMEZONE=Europe/Moscow
ALLOWED_TELEGRAM_USER_IDS=
TELEGRAM_ADMIN_CHECK_ENABLED=true
OPENDOTA_MAX_RETRIES=3
TELEGRAM_SEND_MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=1.0
CONSTANTS_SYNC_INTERVAL_HOURS=24
LOG_LEVEL=INFO
